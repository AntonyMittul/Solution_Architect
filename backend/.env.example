AISA_ENV=dev
# Runtime role (RLS enforced). Migrations use the admin URL below.
AISA_DATABASE_URL=postgresql+asyncpg://aisa_app:aisa_app@localhost:5432/aisa
AISA_DATABASE_ADMIN_URL=postgresql+asyncpg://aisa:aisa@localhost:5432/aisa
AISA_REDIS_URL=redis://localhost:6379/0
AISA_LOG_LEVEL=INFO
# Required outside dev:
# AISA_SECRET_KEY=change-me

# LLM: "gemini" (needs a key) or "fake" (deterministic, no network/key).
# Put real secrets in backend/.env (git-ignored), never in this example file.
AISA_LLM_PROVIDER=gemini
AISA_GEMINI_API_KEY=
AISA_LLM_MODEL_QUALITY=gemini-3.1-flash-lite
AISA_LLM_MODEL_FAST=gemini-3.1-flash-lite

# Observability (OpenTelemetry). Off by default. In dev, enabling prints spans
# to the console; set an OTLP endpoint (and pip install
# opentelemetry-exporter-otlp-proto-http) to export to a collector.
AISA_OTEL_ENABLED=false
AISA_OTEL_ENDPOINT=
AISA_OTEL_SAMPLE_RATIO=1.0
